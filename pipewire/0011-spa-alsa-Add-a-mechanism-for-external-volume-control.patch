 spa/plugins/alsa/acp/ext-volume.h  |  47 ++++
 spa/plugins/alsa/acp/meson.build   |   3 +-
 spa/plugins/alsa/alsa-acp-device.c |   9 +
 src/pipewire/context.c             |  24 +-
 src/pipewire/keys.h                |   1 +
 9 files changed, 758 insertions(+), 88 deletions(-)
 create mode 100644 spa/plugins/alsa/acp/ext-volume.c
 create mode 100644 spa/plugins/alsa/acp/ext-volume.h

diff --git a/spa/plugins/alsa/acp/acp.c b/spa/plugins/alsa/acp/acp.c
index 8f5ea18c2fdf..c6f37e04af7e 100644
